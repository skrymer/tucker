#!/bin/sh
# Pre-commit hook: run static analysis on staged backend / frontend files.
# Skipped when a commit touches neither side. Bypass with --no-verify.
#
# Enabled with:  git config core.hooksPath .githooks
# (run once per clone; see CLAUDE.md).

staged=$(git diff --cached --name-only --diff-filter=ACMR)

if echo "$staged" | grep -q '^frontend/'; then
    echo "pre-commit: linting staged frontend files…"
    (cd frontend && pnpm exec lint-staged) || exit 1
fi

if echo "$staged" | grep -q '^backend/'; then
    echo "pre-commit: running Detekt on the backend…"
    (cd backend && ./gradlew detekt -q) || exit 1
fi
