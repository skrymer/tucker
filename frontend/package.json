{
  "name": "tucker-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "TZ=Etc/UTC playwright test --config playwright.smoke.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nuxt/ui": "^4.8.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "nuxt": "^4.4.6",
    "nuxt-open-fetch": "^0.13.9",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@typescript-eslint/parser": "8.59.4",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "4.3.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,ts,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
