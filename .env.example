# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Cloudflare Tunnel (profile: tunnel) ---
# Zero Trust dashboard -> Networks -> Tunnels -> create -> copy the token.
TUNNEL_TOKEN=

# --- Litestream backup (profile: backup; ungated in prod) ---
# Off-host replication of the SQLite database to Cloudflare R2 (any S3-compatible
# store works). In R2: create a bucket, then an R2 *S3 API token* for the keys.
#   BUCKET   = the bucket name (e.g. tucker-backups)
#   ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com  (R2 account endpoint)
#   REGION   = auto  (R2's region)
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=auto
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# --- Build stamp (managed by deploy/update.sh — do NOT hand-fill) ---
# update.sh upserts these on every deploy so /api/version and the Profile footer
# report the running build, and a bare `docker compose up --build` inherits them
# instead of baking the dev/unknown defaults. Listed here only for visibility.
# APP_VERSION=
# GIT_SHA=
# BUILT_AT=
